{
  "name": "studyhub-app",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node scripts/start.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:smoke": "playwright test --grep @smoke --workers=4",
    "test:e2e:beta": "playwright test --config=playwright.beta.config.js",
    "test:e2e:dark:beta": "playwright test --config=playwright.beta.config.js tests/dark-mode.beta-live.spec.js",
    "test:e2e:dark:beta:update": "playwright test --config=playwright.beta.config.js tests/dark-mode.beta-live.spec.js --update-snapshots",
    "test:e2e:responsive": "playwright test tests/app.responsive.smoke.spec.js",
    "test:e2e:a11y": "playwright test tests/a11y.smoke.spec.js",
    "test:e2e": "playwright test",
    "capture:feed-console": "node scripts/captureFeedConsole.mjs",
    "beta:snapshots": "node scripts/captureBetaSnapshots.mjs",
    "visual:clean": "node tests/helpers/screenshotCleanup.js",
    "visual:capture": "node tests/helpers/screenshotCleanup.js && playwright test visual-baseline && node scripts/generate-gallery.mjs",
    "visual:smoke": "node tests/helpers/screenshotCleanup.js && (playwright test visual-smoke || true) && node scripts/generate-gallery.mjs",
    "visual:dark:beta": "playwright test --config=playwright.beta.config.js tests/dark-mode.beta-live.spec.js",
    "visual:gallery": "node scripts/generate-gallery.mjs",
    "visual:review": "node tests/helpers/screenshotCleanup.js && (playwright test visual-baseline || true) && node scripts/generate-gallery.mjs",
    "mobile:build": "node scripts/build-mobile.js",
    "mobile:sync": "cap sync android",
    "mobile:open": "cap open android",
    "mobile:run": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capgo/capacitor-social-login": "^8.3.20",
    "@codemirror/lang-html": "^6.4.11",
    "@formkit/auto-animate": "^0.9.0",
    "@react-oauth/google": "^0.13.4",
    "@sentry/react": "^10.51.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-code-block-lowlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "animejs": "^4.4.1",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "dompurify": "^3.4.2",
    "focus-trap": "^7.8.0",
    "focus-trap-react": "^11.0.6",
    "highlight.js": "^11.11.1",
    "idb": "^8.0.3",
    "katex": "^0.16.21",
    "lowlight": "^3.3.0",
    "marked": "^17.0.5",
    "posthog-js": "^1.372.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.6",
    "react-error-boundary": "^6.1.1",
    "react-joyride": "^3.1.0",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "sanitize-html": "^2.17.3",
    "serve": "^14.2.5",
    "socket.io-client": "^4.8.3",
    "tippy.js": "^6.3.7",
    "video.js": "^8.23.7",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.54.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "msw": "^2.14.2",
    "rollup-plugin-visualizer": "^6.0.11",
    "vite": "^8.0.5",
    "vitest": "^4.0.4"
  },
  "overrides": {
    "vite": "^8.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
