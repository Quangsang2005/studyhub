# StudyHub frontend environment variables.
# Copy to .env and fill values for your environment.
# Vite exposes only variables prefixed VITE_* to the client bundle.

# ─── REQUIRED ─────────────────────────────────────────────────────────
# Backend API origin (no trailing /api — added per-fetch in code).
# Dev:  http://localhost:4000
# Prod: https://api.getstudyhub.org (or your Railway URL)
VITE_API_URL=http://localhost:4000

# Google OAuth client ID. Required for "Sign in with Google".
# Create at https://console.cloud.google.com → APIs → Credentials.
VITE_GOOGLE_CLIENT_ID=

# Email shown on legal/contact pages and in the support footer.
VITE_SUPPORT_EMAIL=support@example.com

# ─── OPTIONAL: ANALYTICS & MONITORING ─────────────────────────────────
# Sentry frontend DSN. Leave empty to disable browser error reporting.
VITE_SENTRY_DSN=
# Fraction of transactions sampled for performance traces (0.0–1.0).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog product analytics. Leave empty to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft Clarity session replay. Leave empty to disable.
VITE_CLARITY_PROJECT_ID=

# Google Ads conversion tracking. Both values required to fire events;
# leave empty to disable.
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_SIGNUP_CONVERSION_LABEL=

# ─── REMOVED: VITE_TENOR_API_KEY ──────────────────────────────────────
# Tenor key is no longer shipped to the client. GIF search now proxies
# through the backend at /api/gifs/search. Provision `TENOR_API_KEY` on
# the backend (.env) instead.

# ─── OPTIONAL: MOBILE (Capacitor) ────────────────────────────────────
# Override the API origin used by the Capacitor Android shell when it
# runs over LAN against a dev laptop. The desktop dev server still uses
# VITE_API_URL above; only the mobile build switches to this. Auto-set
# by `npm run mobile:build`. See docs/internal/mobile-archive.md §6.
VITE_MOBILE_API_URL=
